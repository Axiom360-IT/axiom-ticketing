    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
